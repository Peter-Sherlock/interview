# PostgreSQL 连接字符串
# 本地: postgresql://postgres:postgres@localhost:5432/interview_db
# Supabase: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/interview_db"

# Cron 任务密钥 (Vercel Cron 调用时需要)
CRON_SECRET="your-cron-secret-change-me"

# 站点 URL (用于 sitemap 等)
NEXT_PUBLIC_SITE_URL="https://your-domain.com"
